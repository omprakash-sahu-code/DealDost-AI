# DealDost AI — Local Environment Variables Example
# Duplicate this file as '.env.local' and fill in your custom credentials.
# Note: Do NOT commit '.env.local' to git!

# 1. MongoDB Connection (Required)
# Retrieve your connection string from the MongoDB Atlas Dashboard:
# Connect -> Connect your application -> Drivers -> Node.js.
# Note: If your local network/DNS blocks SRV records, see the Troubleshooting guide in CONTRIBUTING.md.

MONGODB_URI= #<mongodb+srv://<db_user>:<db_password>@your-cluster.mongodb.net/dealdost_ai?retryWrites=true&w=majority">
DB_NAME=dealdost_ai

# 2. JWT Authentication Secret 
# A secure, long, random string used to sign user cookies.
# DO NOT CHANGE IT.
JWT_SECRET=7dffd6c2834fb545be451901d65db3d1bc4af9c765710ed4d13d22227091c017

# 3. OpenRouter API Credentials (Required)
# Used to interface with the AI generation model (Gemma).
# Sign up at: https://openrouter.ai
# Retrieve your API Key from: Settings -> Keys.
OPENROUTER_API_KEY=  #your-openrouter-api-key.
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1 #(DO NOT CHANGE IT)
AI_MODEL=google/gemma-4-26b-a4b-it
